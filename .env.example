# ============================================================
# Sentinel — Crisis Intelligence Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- REQUIRED: Supabase (crowdsourced reports + realtime) ---
# Create free project: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# --- AI ASSISTANT (pick ONE — OpenAI recommended for tool calling) ---
# Option A: OpenAI (best tool calling) → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
# Option B: Groq (free, fast) → https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key
# Option C: Google Gemini (free tier, no tool calling) → https://aistudio.google.com
GEMINI_API_KEY=AIza...your-gemini-key

# --- VOICE AI (ElevenLabs Conversational AI) ---
# Create agent at: https://elevenlabs.io/app/conversational-ai
# See README for system prompt and tool setup instructions
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# --- 3D GLOBE + Google Maps APIs ---
# Google Cloud Console → Enable: Places, Routes, Geocoding, Elevation, Air Quality, Map Tiles
# Free $200/mo credit covers hackathon use
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...your-maps-key

# --- INTELLIGENCE DATA LAYERS ---
# ACLED Conflict Events → https://acleddata.com/register/
ACLED_API_KEY=your-acled-api-key
ACLED_EMAIL=your@email.com

# OpenSky Network (flights) — optional, anonymous works but registered = higher limits
OPENSKY_USERNAME=optional-opensky-username
OPENSKY_PASSWORD=optional-opensky-password

# --- DEPLOYMENT ---
# Set this to your deployed URL for voice agent webhook + internal API calls
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- APP DEFAULTS ---
NEXT_PUBLIC_DEFAULT_LAT=49.9935
NEXT_PUBLIC_DEFAULT_LNG=36.2304
NEXT_PUBLIC_DEFAULT_ZOOM=12
