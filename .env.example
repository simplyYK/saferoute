# ============================================================
# SafeRoute Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase (required)
# Get from: https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ACLED Conflict Data (required for conflict layer)
# Get from: https://acleddata.com/register/ (free account)
ACLED_API_KEY=your-acled-api-key

# Groq AI (required for chat assistant)
# Get from: https://console.groq.com (free, no credit card)
GROQ_API_KEY=gsk_your-groq-api-key

# Healthsites.io (optional)
# Get from: https://healthsites.io
HEALTHSITES_API_KEY=your-healthsites-key

# App defaults
NEXT_PUBLIC_DEFAULT_LAT=49.9935
NEXT_PUBLIC_DEFAULT_LNG=36.2304
NEXT_PUBLIC_DEFAULT_ZOOM=12
