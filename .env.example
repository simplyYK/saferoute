# ============================================================
# SafeRoute Intelligence — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- REQUIRED: Supabase (crowdsourced reports + realtime) ---
# Create free project: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# --- AI ASSISTANT (pick ONE) ---
# Option A: Groq (free, fast) → https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key
# Option B: OpenAI → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
# Option C: Google Gemini (free tier) → https://aistudio.google.com
GEMINI_API_KEY=AIza...your-gemini-key

# --- 3D GLOBE (optional but spectacular) ---
# Google Photorealistic 3D Tiles → https://console.cloud.google.com → Maps API
# Enable: Map Tiles API. Free $200/mo credit usually covers hackathon use.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...your-maps-key

# --- INTELLIGENCE DATA LAYERS (all free, no key needed except ACLED) ---
# ACLED Conflict Events → https://acleddata.com/register/
ACLED_API_KEY=your-acled-api-key
ACLED_EMAIL=your@email.com

# OpenSky Network (commercial flights) — no key needed, but register for higher limits
# https://opensky-network.org/api/  — anonymous = 10 req/10s, registered = more
OPENSKY_USERNAME=optional-opensky-username
OPENSKY_PASSWORD=optional-opensky-password

# ADSB Exchange (military + unfiltered flights) — no key needed
# Uses: https://adsbexchange.com/data/ public feed

# USGS Earthquakes — no key needed
# Uses: https://earthquake.usgs.gov/earthquakes/feed/v1.0/

# Celestrak Satellites — no key needed
# Uses: https://tle.celestrak.org/SOCRATES/

# --- EXISTING INTEGRATIONS ---
# Healthsites.io (health facilities) → https://healthsites.io
HEALTHSITES_API_KEY=your-healthsites-key

# --- APP DEFAULTS ---
NEXT_PUBLIC_DEFAULT_LAT=49.9935
NEXT_PUBLIC_DEFAULT_LNG=36.2304
NEXT_PUBLIC_DEFAULT_ZOOM=12
